{
  "name": "gnomon",
  "version": "0.1.0",
  "description": "An article/talk split for the LLM wiki pattern.",
  "type": "module",
  "scripts": {
    "mcp": "tsx mcp/server.ts --vault-path vault",
    "site": "tsx site/build.ts vault",
    "site:watch": "tsx site/build.ts vault --watch",
    "site:serve": "tsx site/build.ts vault && cd vault/_site && python3 -m http.server 8000",
    "lint": "tsx mcp/cli.ts lint vault",
    "new-vault": "tsx mcp/cli.ts new-vault",
    "unregister-vault": "tsx mcp/cli.ts unregister-vault",
    "reader": "tsx site/reader.ts vault",
    "reader:serve": "tsx site/reader.ts vault && cd vault/_reader && python3 -m http.server 8000"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
